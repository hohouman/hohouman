---
// 导入页面布局组件
import Layout from '../layouts/Layout.astro';

// 加载个人资料配置数据
import profile from '../config/profile.json';
import gamesData from '../content/_generated/games.json';
import moviesData from '../content/_generated/movies.json';
import booksData from '../content/_generated/books.json';
import OtherContent from '../content/posts/other.md';

const games = Array.isArray(gamesData) ? gamesData : (gamesData.items || []);
const movies = Array.isArray(moviesData) ? moviesData : (moviesData.items || []);
const books = Array.isArray(booksData) ? booksData : (booksData.items || []);

const albumNotes = [
  {
    title: '正在循环',
    desc: '这里以后可以放最近听得最多的专辑、歌单或者一些值得反复回听的作品。',
  },
  {
    title: '喜欢的声音',
    desc: '偏爱的风格、制作人的名字、某种总会被我反复记住的气质。',
  },
  {
    title: '听歌记录',
    desc: '我会把专辑页当作比歌单更安静的一种笔记空间。',
  },
];

const collections = [
  { href: '/games', title: 'Games', desc: '正在游玩的世界、沉迷的系统与难忘的关卡。' },
  { href: '/movies', title: 'Movies', desc: '观影记录与那些会在脑子里停留很久的镜头。' },
  { href: '/books', title: 'Books', desc: '读过的故事、人物和对日常的温柔改写。' },
  { href: '/albums', title: 'Albums', desc: '正在循环的旋律、专辑和耳机里的一点点日常。' },
  { href: '/other', title: 'Other', desc: '音乐、旅途、技术与一些没有被归类的热爱。' },
];

const socialLinks = Object.entries(profile.social).filter(([, url]) => Boolean(url));

const viewerTabs = [
  { key: 'games', label: '游戏' },
  { key: 'movies', label: '电影' },
  { key: 'books', label: '书籍' },
  { key: 'albums', label: '专辑' },
  { key: 'other', label: '其他' },
];

const iconPaths = {
  github: 'M12 2C6.5 2 2 6.5 2 12.2c0 4.6 3 8.4 7.1 9.8.5.1.7-.2.7-.5v-1.8c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.1-1.6-1.1-1.6-.9-.7.1-.7.1-.7 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.7-1.2-4.7-5.5 0-1.2.4-2.1 1.1-2.9-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1.8-.2 1.7-.4 2.6-.4s1.8.1 2.6.4c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.8 1.1 1.7 1.1 2.9 0 4.3-2.4 5.2-4.7 5.5.4.4.8 1 .8 2v2.9c0 .3.2.6.7.5 4.1-1.4 7.1-5.2 7.1-9.8C22 6.5 17.5 2 12 2Z',
  email: 'M4 6.5h16c.8 0 1.5.7 1.5 1.5v8c0 .8-.7 1.5-1.5 1.5H4c-.8 0-1.5-.7-1.5-1.5V8c0-.8.7-1.5 1.5-1.5Zm0 1.6v.2l8 5.1 8-5.1v-.2H4Zm16 8.8V10l-7.6 4.8c-.2.1-.5.1-.8 0L4 10v6.9h16Z',
  default: 'M5 12h14M12 5l7 7-7 7',
};

function getSocialIcon(platform) {
  const key = platform.toLowerCase();
  return iconPaths[key] || iconPaths.default;
}
---

<Layout title="Home" wallpaper={profile.wallpaper} heroFullscreen={true}>
  <div slot="hero" class="landing-hero">
    <section class="profile-panel profile-panel--landing">
      <div class="profile-panel__badge">Personal homepage</div>
      <div class="profile-panel__header">
        <img src={profile.avatar} alt={profile.name} class="profile-avatar" />
        <div>
          <p class="page-kicker page-kicker--hero">Personal logbook</p>
          <h1 class="landing-title">{profile.name}</h1>
        </div>
      </div>
      <p class="landing-bio">{profile.bio}</p>

      <div class="social-icon-row" aria-label="社交媒体">
        {socialLinks.map(([platform, url]) => (
          <a href={url as string} target="_blank" rel="noopener noreferrer" class="social-icon-button" aria-label={platform} title={platform} key={platform}>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d={getSocialIcon(platform)} />
            </svg>
          </a>
        ))}
      </div>
    </section>

    <a href="#content-tabs" class="hero-scroll-link" aria-label="滚动到下一页">
      <span class="hero-scroll-link__label">Scroll</span>
      <span class="hero-scroll-link__arrow" aria-hidden="true">↓</span>
    </a>
  </div>

  <section class="stack home-stage" id="collections">
    <div class="content-stage">
      <div class="content-tabs" id="content-tabs" role="tablist" aria-label="内容切换">
        {viewerTabs.map((tab, index) => (
          <button type="button" class="content-tab" role="tab" aria-selected={index === 0 ? 'true' : 'false'} data-view={tab.key}>
            {tab.label}
          </button>
        ))}
      </div>

      <div class="content-viewer" data-content-viewer>
        <div class="content-viewer__panels">
          <section class="content-panel" data-panel="games" data-active="true">
            <div class="content-panel__summary">
              <p class="section-eyebrow">Games</p>
              <h3>My Game Collection</h3>
              <p>把正在玩、想补完和已经通关的游戏放进同一个更有秩序的清单里。</p>
            </div>
            {games.length > 0 ? (
              <div class="content-panel__list">
                {games.map((game) => (
                  <article class="entry-card entry-card--compact">
                    <div class="entry-card__media">
                      {game.localCoverPath ? <img src={game.localCoverPath} alt={game.title} loading="lazy" /> : null}
                    </div>
                    <div class="entry-card__body">
                      <span class="card-tag">Game</span>
                      <h3 class="entry-card__title">{game.title}</h3>
                      {game.description ? <p class="entry-card__desc">{game.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                      <div class="entry-card__meta">
                        <div><strong>Developer:</strong> {Array.isArray(game.developer) ? game.developer.join(', ') : game.developer || 'Unknown'}</div>
                        <div><strong>Publisher:</strong> {Array.isArray(game.publisher) ? game.publisher.join(', ') : game.publisher || 'Unknown'}</div>
                        <div><strong>Release:</strong> {game.releaseDate || 'TBA'}</div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="empty-state">No games added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="movies">
            <div class="content-panel__summary">
              <p class="section-eyebrow">Movies</p>
              <h3>My Movie Collection</h3>
              <p>更克制的留白和更明确的信息层级，会让影单本身更像一份认真整理过的笔记。</p>
            </div>
            {movies.length > 0 ? (
              <div class="content-panel__list">
                {movies.map((movie) => (
                  <article class="entry-card entry-card--compact">
                    <div class="entry-card__media">
                      {movie.localCoverPath ? <img src={movie.localCoverPath} alt={movie.title} loading="lazy" /> : null}
                    </div>
                    <div class="entry-card__body">
                      <span class="card-tag">Movie</span>
                      <h3 class="entry-card__title">{movie.title}</h3>
                      {movie.description ? <p class="entry-card__desc">{movie.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                      <div class="entry-card__meta">
                        <div><strong>Director:</strong> {Array.isArray(movie.director) ? movie.director.join(', ') : movie.director || 'Unknown'}</div>
                        <div><strong>Release:</strong> {movie.releaseDate || 'TBA'}</div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="empty-state">No movies added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="books">
            <div class="content-panel__summary">
              <p class="section-eyebrow">Books</p>
              <h3>My Book Collection</h3>
              <p>书单页采用更安静的排版，避免封面之外的元素抢走阅读的注意力。</p>
            </div>
            {books.length > 0 ? (
              <div class="content-panel__list">
                {books.map((book) => (
                  <article class="entry-card entry-card--compact">
                    <div class="entry-card__media">
                      {book.localCoverPath ? <img src={book.localCoverPath} alt={book.title} loading="lazy" /> : null}
                    </div>
                    <div class="entry-card__body">
                      <span class="card-tag">Book</span>
                      <h3 class="entry-card__title">{book.title}</h3>
                      {book.description ? <p class="entry-card__desc">{book.description}</p> : <p class="entry-card__desc">No description provided.</p>}
                      <div class="entry-card__meta">
                        <div><strong>Author:</strong> {Array.isArray(book.developer) ? book.developer.join(', ') : book.developer || 'Unknown'}</div>
                        <div><strong>Publisher:</strong> {Array.isArray(book.publisher) ? book.publisher.join(', ') : book.publisher || 'Unknown'}</div>
                        <div><strong>Release:</strong> {book.releaseDate || 'TBA'}</div>
                      </div>
                    </div>
                  </article>
                ))}
              </div>
            ) : (
              <div class="empty-state">No books added yet. Check back later!</div>
            )}
          </section>

          <section class="content-panel" data-panel="albums">
            <div class="content-panel__summary">
              <p class="section-eyebrow">Albums</p>
              <h3>My Album Notes</h3>
              <p>这是一页关于专辑和声音的私人笔记。它比歌单更安静，比自我介绍更直接。</p>
            </div>
            <div class="content-panel__notes">
              {albumNotes.map((item) => (
                <article class="entry-card entry-card--compact">
                  <div class="entry-card__body">
                    <span class="card-tag">Album</span>
                    <h3 class="entry-card__title">{item.title}</h3>
                    <p class="entry-card__desc">{item.desc}</p>
                  </div>
                </article>
              ))}
            </div>
          </section>

          <section class="content-panel" data-panel="other">
            <div class="content-panel__summary">
              <p class="section-eyebrow">Other</p>
              <h3>My Other Interests</h3>
              <p>不想塞进游戏、电影或书籍里的内容，最终都收拢到这个更自由的分区。</p>
            </div>
            <div class="prose-card">
              <OtherContent />
            </div>
          </section>
        </div>

        <div class="content-panel__controls">
          <button type="button" class="content-nav-button" data-step="prev" aria-label="上一项">←</button>
          <button type="button" class="content-nav-button" data-step="next" aria-label="下一项">→</button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const viewer = document.querySelector('[data-content-viewer]');
  const tabs = Array.from(document.querySelectorAll('[data-view]'));
  const panels = Array.from(document.querySelectorAll('[data-panel]'));
  const labelByKey = {
    games: '游戏',
    movies: '电影',
    books: '书籍',
    albums: '专辑',
    other: '其他',
  };

  if (viewer && tabs.length && panels.length) {
    const keys = tabs.map((tab) => tab.dataset.view);

    const setActive = (key) => {
      tabs.forEach((tab) => {
        const isActive = tab.dataset.view === key;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        panel.dataset.active = panel.dataset.panel === key ? 'true' : 'false';
      });

      viewer.dataset.activeView = key;
    };

    const getCurrentKey = () => viewer.dataset.activeView || 'games';

    const move = (direction) => {
      const currentKey = getCurrentKey();
      const currentIndex = keys.indexOf(currentKey);
      const nextIndex = direction === 'next'
        ? (currentIndex + 1) % keys.length
        : (currentIndex - 1 + keys.length) % keys.length;
      setActive(keys[nextIndex] || 'games');
    };

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => setActive(tab.dataset.view || 'games'));
    });

    viewer.querySelectorAll('[data-step]').forEach((button) => {
      button.addEventListener('click', () => move(button.dataset.step));
    });

    setActive('games');
  }
</script>